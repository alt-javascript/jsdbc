{
  "name": "jsdbc",
  "private": true,
  "version": "1.0.0",
  "description": "JDBC-inspired database access facade for JavaScript — pluggable drivers, isomorphic",
  "keywords": [
    "db",
    "jdbc",
    "database",
    "drivers",
    "facade"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://github.com/alt-javascript/jsdbc#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/alt-javascript/jsdbc"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm test -w packages/core -w packages/sqlite -w packages/sqljs",
    "test:integration": "npm test --workspaces --if-present",
    "lint": "eslint packages/*/**.js --fix"
  },
  "author": "Craig Parravicini",
  "license": "MIT"
}
